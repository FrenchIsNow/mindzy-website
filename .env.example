WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v18.0

NEXT_PUBLIC_SITE_URL=https://mindzy.me
# Google Calendar / Workspace: link to your appointment schedule (Calendar → Booking pages → Copy link)
NEXT_PUBLIC_CALENDLY_URL=
# Optional: Google Calendar inline booking page. Calendar → Booking pages → your schedule → "Inline booking page" → copy the iframe src URL here. Shown below the "Prendre un rendez-vous" button on guide detail pages.
NEXT_PUBLIC_BOOKING_EMBED_URL=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Sheets webhook URL (Google Apps Script web app URL)
# See setup instructions below
GOOGLE_SHEETS_WEBHOOK_URL=

# Contact form webhook — writes to MINDZY_FORM_FILLED sheet in CRM
# Falls back to GOOGLE_SHEETS_WEBHOOK_URL if not set
GOOGLE_SHEETS_CONTACT_FORM_URL=

# Google reCAPTCHA v3 keys
# Get your keys at: https://www.google.com/recaptcha/admin (select reCAPTCHA v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
